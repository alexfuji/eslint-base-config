{
  "name": "@alexfuji/eslint-base-config",
  "version": "1.0.7",
  "description": "Base ESLint configuration for JavaScript/TypeScript projects",
  "type": "module",
  "main": "eslint.config.js",
  "scripts": {
    "install:auth": "env-cmd -f .env npm install",
    "release": "npx standard-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexfuji/eslint-base-config.git"
  },
  "keywords": [
    "eslint",
    "config",
    "typescript"
  ],
  "author": "Alex Fuji",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexfuji/eslint-base-config/issues"
  },
  "homepage": "https://github.com/alexfuji/eslint-base-config#readme",
  "dependencies": {
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "env-cmd": "^10.1.0",
    "standard-version": "^9.3.2"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  }
}
